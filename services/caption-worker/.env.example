PORT=8080
WORKER_SECRET=replace-me

# Cloud Run can use ADC by default. Set these only when running with an explicit service account key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

CAPTION_PREFERRED_LANGS=ja,en
YT_DLP_BINARY=yt-dlp
YT_DLP_COOKIES_PATH=/secrets/youtube-cookies/cookies.txt

JOB_DISPATCH_BATCH_SIZE=5
JOB_LOCK_TIMEOUT_MS=75000
JOB_MAX_ATTEMPTS=6
JOB_BACKOFF_BASE_SECONDS=30
MATERIAL_PIPELINE_BATCH_WRITE_LIMIT=400
