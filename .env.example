# Firebase Client SDK (required)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Firebase Admin SDK (required for server routes / workers)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Internal API auth
# CRON_SECRET: /api/cron/jobs and cron-compatible callers
# WORKER_SECRET: /api/worker/* and internal worker-to-worker calls
CRON_SECRET=replace-with-long-random-secret
WORKER_SECRET=replace-with-long-random-secret

# YouTube captions fetcher (optional tuning for yt-dlp)
# YT_DLP_TIMEOUT_MS / YT_DLP_RETRIES are also used by the built-in fetch provider.
YT_DLP_PATH=yt-dlp
YT_DLP_TIMEOUT_MS=120000
YT_DLP_SUB_LANGS=en.*,en
YT_DLP_RETRIES=3
YT_DLP_EXTRACTOR_ARGS=youtube:player_client=tv,android,web
# Set either YT_DLP_COOKIES_PATH OR YT_DLP_COOKIES_FROM_BROWSER when YouTube blocks anonymous requests.
# Example browser values: chrome / edge / firefox
YT_DLP_COOKIES_PATH=
YT_DLP_COOKIES_FROM_BROWSER=
# Optional override for network/device fingerprint compatibility.
YT_DLP_USER_AGENT=

# OpenAI (server-only)
# OPENAI_MODEL / OPENAI_BASE_URL / OPENAI_TIMEOUT_MS are optional.
# Defaults: gpt-4o-mini / https://api.openai.com/v1 / 8000
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=8000
